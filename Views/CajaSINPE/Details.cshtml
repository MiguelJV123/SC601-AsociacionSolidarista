@model proyecto.asociacionsolidarista.Models.Entities.CajaSINPE

@{
    ViewBag.Title = "Detalles de Caja SINPE";
}

<div class="container mt-4">
    <h2>Detalles de Caja SINPE</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">Comercio Asociado</dt>
                <dd class="col-sm-8">@(Model.Comercio != null ? Model.Comercio.Nombre : "Sin asignar")</dd>

                <dt class="col-sm-4">Nombre</dt>
                <dd class="col-sm-8">@Model.Nombre</dd>

                <dt class="col-sm-4">Descripcion</dt>
                <dd class="col-sm-8">@Model.Descripcion</dd>

                <dt class="col-sm-4">Telefono SINPE</dt>
                <dd class="col-sm-8">@Model.TelefonoSINPE</dd>

                <dt class="col-sm-4">Fecha de Registro</dt>
                <dd class="col-sm-8">@Model.FechaDeRegistro.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-4">Fecha de Modificacion</dt>
                <dd class="col-sm-8">
                    @(Model.FechaDeModificacion.HasValue ? Model.FechaDeModificacion.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")
                </dd>

                <dt class="col-sm-4">Estado</dt>
                <dd class="col-sm-8">
                    @if (Model.Estado == 1)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
                </dd>
            </dl>

            <div class="mt-3">
                <a href="@Url.Action("Edit", new { id = Model.IdCaja })" class="btn btn-warning">Editar</a>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Volver a la lista</a>
            </div>
        </div>
    </div>
</div>
