@model proyecto.asociacionsolidarista.Models.Entities.Comercio

@{
    ViewBag.Title = "Eliminar Comercio";
}

<div class="container mt-4">
    <h2>Eliminar Comercio</h2>
    <h3 class="text-danger">Seguro que desea desactivar este Comercio?</h3>
    <p class="text-warning">
        Esta accion no borrara el comercio permanentemente de la base de datos para preservar el historial de Cajas y Pagos,
        pero cambiara su estado a Inactivo.
    </p>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">Identificacion</dt>
                <dd class="col-sm-8">@Model.Identificacion</dd>

                <dt class="col-sm-4">Nombre</dt>
                <dd class="col-sm-8">@Model.Nombre</dd>

                <dt class="col-sm-4">Telefono</dt>
                <dd class="col-sm-8">@Model.Telefono</dd>

                <dt class="col-sm-4">Correo Electronico</dt>
                <dd class="col-sm-8">@Model.CorreoElectronico</dd>
            </dl>

            @using (Html.BeginForm("Delete", "Comercio", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.IdComercio)

                <div class="mt-3">
                    <button type="submit" class="btn btn-danger">Confirmar Desactivacion</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
                </div>
            }
        </div>
    </div>
</div>
