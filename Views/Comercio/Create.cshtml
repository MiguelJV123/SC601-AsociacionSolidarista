@model proyecto.asociacionsolidarista.Models.Entities.Comercio

@{
    ViewBag.Title = "Nuevo Comercio";
}

<h2>Nuevo Comercio</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">

        <hr />

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">

            @Html.LabelFor(m => m.Identificacion, "Identificación", new { @class = "control-label col-md-2" })

            <div class="col-md-10">

                @Html.TextBoxFor(m => m.Identificacion, new
                {
                    @class = "form-control",
                    placeholder = "Ej: 3101123456"
                })

                @Html.ValidationMessageFor(m => m.Identificacion, "", new { @class = "text-danger" })

            </div>

        </div>

        <div class="form-group">

            @Html.LabelFor(m => m.TipoIdentificacion, "Tipo de Identificación", new { @class = "control-label col-md-2" })

            <div class="col-md-10">

                @Html.DropDownListFor(
                    m => m.TipoIdentificacion,
                    new List<SelectListItem>
                    {
                        new SelectListItem
                        {
                            Text = "-- Seleccione un tipo --",
                            Value = "",
                            Disabled = true,
                            Selected = true
                        },
                        new SelectListItem { Text = "Física", Value = "1" },
                        new SelectListItem { Text = "Jurídica", Value = "2" },
                        new SelectListItem { Text = "DIMEX", Value = "3" },
                        new SelectListItem { Text = "Pasaporte", Value = "4" }
                    },
                    new
                    {
                        @class = "form-control",
                        style = "height:38px;"
                    })

                @Html.ValidationMessageFor(m => m.TipoIdentificacion, "", new { @class = "text-danger" })

            </div>

        </div>

        <div class="form-group">

            @Html.LabelFor(m => m.Nombre, "Nombre", new { @class = "control-label col-md-2" })

            <div class="col-md-10">

                @Html.TextBoxFor(m => m.Nombre, new
                {
                    @class = "form-control",
                    placeholder = "Nombre del comercio"
                })

                @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })

            </div>

        </div>

        <div class="form-group">

            @Html.LabelFor(m => m.Telefono, "Teléfono", new { @class = "control-label col-md-2" })

            <div class="col-md-10">

                @Html.TextBoxFor(m => m.Telefono, new
                {
                    @class = "form-control",
                    placeholder = "8888-8888"
                })

                @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger" })

            </div>

        </div>

        <div class="form-group">

            @Html.LabelFor(m => m.CorreoElectronico, "Correo Electrónico", new { @class = "control-label col-md-2" })

            <div class="col-md-10">

                @Html.TextBoxFor(m => m.CorreoElectronico, new
                {
                    @class = "form-control",
                    type = "email",
                    placeholder = "ejemplo@correo.com"
                })

                @Html.ValidationMessageFor(m => m.CorreoElectronico, "", new { @class = "text-danger" })

            </div>

        </div>

        <div class="form-group">

            @Html.LabelFor(m => m.Direccion, "Dirección", new { @class = "control-label col-md-2" })

            <div class="col-md-10">

                @Html.TextAreaFor(m => m.Direccion, 4, 50, new
                {
                    @class = "form-control",
                    placeholder = "Dirección exacta del comercio"
                })

                @Html.ValidationMessageFor(m => m.Direccion, "", new { @class = "text-danger" })

            </div>

        </div>

        <div class="form-group">

            @Html.LabelFor(m => m.Estado, "Estado", new { @class = "control-label col-md-2" })

            <div class="col-md-10">

                @Html.DropDownListFor(
                    m => m.Estado,
                    new List<SelectListItem>
                    {
                        new SelectListItem { Text = "Activo", Value = "1" },
                        new SelectListItem { Text = "Inactivo", Value = "0" }
                    },
                    new
                    {
                        @class = "form-control",
                        style = "height:38px;"
                    })

                @Html.ValidationMessageFor(m => m.Estado, "", new { @class = "text-danger" })

            </div>

        </div>

        <div class="form-group">

            <div class="col-md-offset-2 col-md-10">

                <input type="submit"
                       value="Guardar"
                       class="btn btn-primary" />

                @Html.ActionLink("Cancelar",
                                 "Index",
                                 null,
                                 new { @class = "btn btn-default" })

            </div>

        </div>

    </div>
}