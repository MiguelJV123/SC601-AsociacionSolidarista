@model IEnumerable<proyecto.asociacionsolidarista.Models.Entities.Comercio>

@{
    ViewBag.Title = "Gestión de Comercios";
}

<h2>Gestión de Comercios</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<p>
    @Html.ActionLink("Nuevo Comercio", "Create", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-bordered table-striped table-hover">

    <thead>

        <tr>

            <th>Identificación</th>

            <th>Nombre</th>

            <th>Teléfono</th>

            <th>Correo Electrónico</th>

            <th>Estado</th>

            <th width="260">Acciones</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Identificacion</td>

                <td>@item.Nombre</td>

                <td>@item.Telefono</td>

                <td>@item.CorreoElectronico</td>

                <td>
                    @(item.Estado == 1 ? "Activo" : "Inactivo")
                </td>

                <td>

                    @Html.ActionLink(
                        "Ver",
                        "Details",
                        new { id = item.IdComercio },
                        new { @class = "btn btn-info btn-xs" })

                    @Html.Raw(" ")

                    @Html.ActionLink(
                        "Editar",
                        "Edit",
                        new { id = item.IdComercio },
                        new { @class = "btn btn-warning btn-xs" })

                    @Html.Raw(" ")

                    @Html.ActionLink(
                        "Eliminar",
                        "Delete",
                        new { id = item.IdComercio },
                        new { @class = "btn btn-danger btn-xs" })

                </td>

            </tr>
        }

    </tbody>

</table>