@model proyecto.asociacionsolidarista.Models.Entities.PagoSINPE

@{
    ViewBag.Title = "Eliminar Pago SINPE";
}

<div class="container mt-4">
    <h2>Eliminar Pago SINPE</h2>
    <h3 class="text-danger">Seguro que desea eliminar este Pago SINPE?</h3>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">Caja SINPE</dt>
                <dd class="col-sm-8">@(Model.CajaSINPE != null ? Model.CajaSINPE.Nombre : "Sin asignar")</dd>

                <dt class="col-sm-4">Origen</dt>
                <dd class="col-sm-8">@Model.NombreOrigen (@Model.TelefonoOrigen)</dd>

                <dt class="col-sm-4">Destino</dt>
                <dd class="col-sm-8">@Model.NombreDestinatario (@Model.TelefonoDestinatario)</dd>

                <dt class="col-sm-4">Monto</dt>
                <dd class="col-sm-8">@Model.Monto.ToString("C")</dd>
            </dl>

            @using (Html.BeginForm("Delete", "PagoSINPE", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.IdSinpe)

                <div class="mt-3">
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
                </div>
            }
        </div>
    </div>
</div>
