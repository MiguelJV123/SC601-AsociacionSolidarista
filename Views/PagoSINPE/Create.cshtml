@model proyecto.asociacionsolidarista.Models.Entities.PagoSINPE

@{
    ViewBag.Title = "Nuevo Pago SINPE";
}

<div class="container mt-4">
    <h2>Nuevo Pago SINPE</h2>
    <hr />

    @using (Html.BeginForm("Create", "PagoSINPE", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    @Html.LabelFor(m => m.IdCaja, "Caja SINPE Destino", new { @class = "form-label" })
                    @Html.DropDownList("IdCaja", null, "Seleccione una Caja", htmlAttributes: new { @class = "form-select", required = "required" })
                    @Html.ValidationMessageFor(m => m.IdCaja, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.TelefonoOrigen, "Telefono Origen", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.TelefonoOrigen, new { @class = "form-control", required = "required", maxlength = "10" })
                    @Html.ValidationMessageFor(m => m.TelefonoOrigen, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.NombreOrigen, "Nombre Origen", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.NombreOrigen, new { @class = "form-control", required = "required", maxlength = "200" })
                    @Html.ValidationMessageFor(m => m.NombreOrigen, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.TelefonoDestinatario, "Telefono Destinatario", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.TelefonoDestinatario, new { @class = "form-control", required = "required", maxlength = "10" })
                    @Html.ValidationMessageFor(m => m.TelefonoDestinatario, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.NombreDestinatario, "Nombre Destinatario", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.NombreDestinatario, new { @class = "form-control", required = "required", maxlength = "200" })
                    @Html.ValidationMessageFor(m => m.NombreDestinatario, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Monto, "Monto", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Monto, new { @class = "form-control", type = "number", step = "0.01", min = "0", required = "required" })
                    @Html.ValidationMessageFor(m => m.Monto, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Descripcion, "Descripcion", new { @class = "form-label" })
                    @Html.TextAreaFor(m => m.Descripcion, new { @class = "form-control", maxlength = "50", rows = "2" })
                    @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Estado, "Estado", new { @class = "form-label" })
                    @Html.DropDownListFor(m => m.Estado, new SelectList(new[]
                    {
                        new { Value = "1", Text = "Activo" },
                        new { Value = "0", Text = "Anulado" }
                    }, "Value", "Text"), new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.Estado, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
                </div>
            </div>
        </div>
    }
</div>
