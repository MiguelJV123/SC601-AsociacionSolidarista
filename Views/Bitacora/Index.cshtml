@model IEnumerable<proyecto.asociacionsolidarista.Models.Entities.BitacoraEventos>

@{
    ViewBag.Title = "Bitacora de Eventos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Bitacora de Eventos</h2>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Tabla</th>
                    <th>Tipo</th>
                    <th>Descripcion</th>
                    <th>Pago Relacionado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center">No hay registros en la bitacora.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FechaDeEvento.ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td>@item.TablaDeEvento</td>
                            <td>@item.TipoDeEvento</td>
                            <td>@item.DescripcionDeEvento</td>
                            <td>
                                @(item.IdSinpe.HasValue ? "Pago ID: " + item.IdSinpe.ToString() : "N/A")
                            </td>
                            <td>
                                <a href="@Url.Action("Details", new { id = item.IdEvento })" class="btn btn-sm btn-info">Detalles</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
